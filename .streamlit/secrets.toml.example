# Copy to .streamlit/secrets.toml and fill in. NEVER commit the real file.
# Source structure (tables/columns) lives in registry/sources.yaml — only creds here.

# --- Section 1 brand/period variables (runtime config) ---
BRAND_NAME         = "Acme Corp"
BRAND_DESCRIPTION  = "B2B SaaS for logistics"
PERIOD             = "Q1 FY25"
CURRENCY_SYMBOL    = "$"
CURRENCY_SHORTHAND = "M/K"

# --- Claude ---
ANTHROPIC_API_KEY  = ""            # required for live answers
CLAUDE_MODEL       = "claude-opus-4-7"

# --- Snowflake (source: revenue_db) ---
SNOWFLAKE_ACCOUNT   = ""
SNOWFLAKE_USER      = ""
SNOWFLAKE_PASSWORD  = ""
SNOWFLAKE_WAREHOUSE = "COMPUTE_WH"
SNOWFLAKE_ROLE      = ""           # optional

# --- Google Sheets (sources: pipeline_sheet, campaigns_sheet) ---
GOOGLE_SERVICE_ACCOUNT_PATH = ""   # path to service-account JSON
DRIVE_FOLDER_ID             = ""   # optional

# --- Inactive templates (fill when you flip active: true in sources.yaml) ---
# POSTGRES_URL = "postgresql://user:pass@host:5432/db"   # finance_db
# MYSQL_URL    = "mysql://user:pass@host:3306/db"        # hr_db
# BQ_PROJECT_ID = ""                                      # bigquery sources
